{
  "name": "@blade47/react-scheduler",
  "private": false,
  "version": "1.0.9",
  "description": "React scheduler component based on Material-UI & Dayjs",
  "type": "module",
  "main": "./index.js",
  "module": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "import": "./index.js",
      "require": "./index.cjs"
    }
  },
  "files": [
      "index.js",
      "index.cjs",
      "index.d.ts",
      "index.css",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev:demo": "cd src/demo && yarn run dev",
    "build:demo": "cd src/demo && yarn run build",
    "dev": "vite",
    "build": "tsc && vite build",
    "lint": "eslint \"src/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"src/**/*.{js,jsx,ts,tsx}\"",
    "prettier": "prettier --write \"src/**/*.{js,jsx,ts,tsx}\"",
    "preview": "vite preview",
    "prepublishOnly": "npm run build",
    "clean": "rimraf dist",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "author": {
    "name": "Alessandro Afloarei"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ernst77/react-scheduler"
  },
  "license": "MIT",
  "peerDependencies": {
    "@emotion/react": "^11.x",
    "@emotion/styled": "^11.x",
    "@mui/icons-material": "^7.x",
    "@mui/material": "^7.x",
    "dayjs": "^1.11.13",
    "react": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "react-dom": "^17.0.0 || ^18.0.0 || ^19.0.0",
    "rrule": "^2.8.1"
  },
  "peerDependenciesMeta": {
    "@emotion/react": {
      "optional": false
    },
    "@emotion/styled": {
      "optional": false
    },
    "@mui/material": {
      "optional": false
    },
    "dayjs": {
      "optional": false
    },
    "rrule": {
      "optional": false
    }
  },
  "dependencies": {
    "@fontsource/manrope": "^5.1.1",
    "@fontsource/open-sans": "^5.1.1",
    "@hookform/resolvers": "^4.1.3",
    "@mui/x-date-pickers": "^7.28.2",
    "lodash.merge": "^4.6.2",
    "react-hook-form": "^7.55.0",
    "yup": "^1.6.1"
  },
  "devDependencies": {
    "@babel/preset-react": "^7.26.3",
    "@emotion/babel-plugin": "^11.x",
    "@emotion/react": "^11.14.0",
    "@emotion/styled": "^11.14.0",
    "@eslint/js": "^9.19.0",
    "@mui/icons-material": "^7.0.2",
    "@mui/material": "^7.0.1",
    "@types/lodash.merge": "^4.6.9",
    "@types/node": "^22.13.14",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "@vitejs/plugin-react-swc": "^3.8.1",
    "dayjs": "^1.11.13",
    "eslint": "^9.23.0",
    "eslint-config-prettier": "^10.0.1",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.18",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "rimraf": "^5.0.0",
    "rrule": "^2.8.1",
    "terser": "^5.x",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^6.2.4",
    "vite-plugin-dts": "^4.5.0"
  },
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "react",
    "material-ui",
    "calendar",
    "scheduler"
  ],
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
